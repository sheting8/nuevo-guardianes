generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── AUTH ──────────────────────────────────────────────────────────────────────

model User {
  id            String         @id @default(cuid())
  username      String         @unique
  passwordHash  String
  voluntario    Voluntario?
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── VOLUNTARIOS ───────────────────────────────────────────────────────────────

enum TipoVoluntario {
  QUINCE
  CONFEDERADO
}

enum RolSistema {
  ADMIN
  JEFE_GUARDIA
  GUARDIAN
  CONDUCTOR
  OFICIALIDAD
}

model Voluntario {
  id          String         @id @default(cuid())
  correlativo Int
  tipo        TipoVoluntario
  activo      Boolean        @default(true)
  eliminado   Boolean        @default(false)
  eliminadoEn DateTime?
  userId      String?        @unique
  user        User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  nombres     String
  apellidoP   String
  apellidoM   String?
  rut         String
  rutDigito   String
  company     Int
  email       String
  telefono    String?
  fechaNacimiento DateTime? @db.Date
  roles             VoluntarioRol[]
  camasAsignadas    CamaAsignacion[]
  permisosEmitidos  Permiso[]          @relation("solicitante")
  permisosRecibidos Permiso[]          @relation("reemplazante")
  correccionesComoVoluntario CorreccionNoche[] @relation("voluntario")
  correccionesComoAutor      CorreccionNoche[] @relation("autor")
  mensajero         Mensajero[]
  conductorGuardia  ConductorGuardia[]
  jgsSubrogante     JGsSubrogante[]
  licencias         Licencia[]
  turnosVoluntario  TurnoVoluntario[]
  calendarioConductor CalendarioConductor[]
  carrosHabilitados   CarroVoluntario[]
  oficialidad       Oficialidad?
  grupos              GrupoMiembro[]
  autorizaciones       Autorizacion[]
  checklistEjecuciones ChecklistEjecucion[]
  notificaciones       Notificacion[]
  dispositivos         DispositivoNotificacion[]
}

model VoluntarioRol {
  voluntarioId String
  rol          RolSistema
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@id([voluntarioId, rol])
}

model Oficialidad {
  id           String     @id @default(cuid())
  cargo        String
  voluntarioId String     @unique
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)
}

// ── GUARDIA ───────────────────────────────────────────────────────────────────

model Turno {
  id          String            @id @default(cuid())
  nombre      String
  voluntarios TurnoVoluntario[]
  citaciones  Citacion[]
}

model TurnoVoluntario {
  turnoId      String
  voluntarioId String
  turno        Turno      @relation(fields: [turnoId], references: [id], onDelete: Cascade)
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@id([turnoId, voluntarioId])
}

model Citacion {
  id          String           @id @default(cuid())
  turnoId     String?
  turno       Turno?           @relation(fields: [turnoId], references: [id], onDelete: SetNull)
  fechaInicio DateTime         @db.Date
  fechaFin    DateTime?        @db.Date
  camas       CamaAsignacion[]
  createdAt   DateTime         @default(now())
}

model CamaAsignacion {
  id           String     @id @default(cuid())
  citacionId   String
  citacion     Citacion   @relation(fields: [citacionId], references: [id], onDelete: Cascade)
  numeroCama   Int
  voluntarioId String
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Restrict)

  @@unique([citacionId, numeroCama])
}

enum TipoPermiso {
  PERMISO
  PERMISO_ESPECIAL
  REEMPLAZO
}

enum EstadoPermiso {
  PENDIENTE
  APROBADO
  RECHAZADO
}

model Permiso {
  id             String        @id @default(cuid())
  solicitanteId  String
  solicitante    Voluntario    @relation("solicitante", fields: [solicitanteId], references: [id], onDelete: Cascade)
  tipo           TipoPermiso
  reemplazanteId String?
  reemplazante   Voluntario?   @relation("reemplazante", fields: [reemplazanteId], references: [id], onDelete: SetNull)
  fechaGuardia   DateTime      @db.Date
  estado         EstadoPermiso @default(PENDIENTE)
  comentarios    String?
  fechaEnvio     DateTime      @default(now())
  fechaCierre    DateTime?
}

model CorreccionNoche {
  id           String     @id @default(cuid())
  fecha        DateTime   @db.Date
  voluntarioId String
  voluntario   Voluntario @relation("voluntario", fields: [voluntarioId], references: [id], onDelete: Cascade)
  durmio       Boolean
  autorId      String
  autor        Voluntario @relation("autor", fields: [autorId], references: [id], onDelete: Restrict)
  creadoEn     DateTime   @default(now())

  @@unique([fecha, voluntarioId])
}

model Mensajero {
  id           String     @id @default(cuid())
  fecha        DateTime   @unique @db.Date
  voluntarioId String
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Restrict)
}

model ConductorGuardia {
  id           String     @id @default(cuid())
  fecha        DateTime   @db.Date
  voluntarioId String
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Restrict)

  @@unique([fecha, voluntarioId])
}

model JGsSubrogante {
  id           String     @id @default(cuid())
  fecha        DateTime   @unique @db.Date
  voluntarioId String
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Restrict)
}

model Licencia {
  id           String     @id @default(cuid())
  fecha        DateTime   @db.Date
  voluntarioId String
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@unique([fecha, voluntarioId])
}

// ── CONDUCTORES CBS ───────────────────────────────────────────────────────────

model Cuartelero {
  id           String            @id @default(cuid())
  nombre       String
  clave        String
  nacimiento   DateTime?         @db.Date
  fechaIngreso DateTime?         @db.Date
  vigente      Boolean           @default(true)
  pauta        Pauta[]
  carros       CarroCuartelero[]
}

model Pauta {
  id           String     @id @default(cuid())
  cuarteleroId String
  cuartelero   Cuartelero @relation(fields: [cuarteleroId], references: [id], onDelete: Cascade)
  fecha        DateTime   @db.Date

  @@unique([cuarteleroId, fecha])
}

model Carro {
  id          String                @id @default(cuid())
  nombre      String
  voluntarios CarroVoluntario[]
  cuarteleros CarroCuartelero[]
  turnos      CalendarioConductorCarro[]
  ubicaciones Ubicacion[]
}

model CarroVoluntario {
  carroId      String
  voluntarioId String
  carro        Carro      @relation(fields: [carroId], references: [id], onDelete: Cascade)
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@id([carroId, voluntarioId])
}

model CarroCuartelero {
  carroId      String
  cuarteleroId String
  carro        Carro      @relation(fields: [carroId], references: [id], onDelete: Cascade)
  cuartelero   Cuartelero @relation(fields: [cuarteleroId], references: [id], onDelete: Cascade)

  @@id([carroId, cuarteleroId])
}

model CalendarioConductor {
  id            String                     @id @default(cuid())
  voluntarioId  String
  voluntario    Voluntario                 @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)
  fechaInicio   DateTime                   @db.Date
  fechaFin      DateTime                   @db.Date
  observaciones String?
  carros        CalendarioConductorCarro[]
}

model CalendarioConductorCarro {
  calendarioId String
  carroId      String
  calendario   CalendarioConductor @relation(fields: [calendarioId], references: [id], onDelete: Cascade)
  carro        Carro               @relation(fields: [carroId], references: [id], onDelete: Cascade)

  @@id([calendarioId, carroId])
}

// ── RBAC (nuevo, aditivo — RolSistema/@Roles() sigue vigente sin cambios) ──────
//
// Autorizacion.recursoId es deliberadamente genérico (sin FK de BD) en vez de
// una columna nullable por tipo de recurso: el objetivo explícito es que este
// RBAC crezca a nuevos tipos de recurso (y eventualmente a lo que hoy cubre
// RolSistema) agregando un valor de enum, no una migración de esquema cada vez.
// El costo real de esa decisión: no hay cascade-delete automático ni chequeo de
// tipo a nivel de BD — el service layer de cada recurso debe borrar las
// Autorizacion/ChecklistTemplate que lo referencian al eliminarlo, y validar que
// un recursoId corresponda a un recurso real de ese tipo antes de crear el grant.

model Grupo {
  id              String         @id @default(cuid())
  nombre          String
  descripcion     String?
  miembros        GrupoMiembro[]
  autorizaciones  Autorizacion[]
  createdAt       DateTime       @default(now())
}

model GrupoMiembro {
  grupoId      String
  voluntarioId String
  grupo        Grupo      @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  voluntario   Voluntario @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)

  @@id([grupoId, voluntarioId])
  @@index([voluntarioId])
}

enum NivelAcceso {
  LEER
  GESTIONAR
}

enum TipoRecursoAcceso {
  CATEGORIA_INVENTARIO
  UBICACION
  CHECKLIST_TEMPLATE
}

enum TipoSujetoAcceso {
  USUARIO
  GRUPO
}

model Autorizacion {
  id           String            @id @default(cuid())
  sujetoTipo   TipoSujetoAcceso
  voluntarioId String?
  voluntario   Voluntario?       @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)
  grupoId      String?
  grupo        Grupo?            @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  recursoTipo  TipoRecursoAcceso
  recursoId    String
  nivel        NivelAcceso
  createdAt    DateTime          @default(now())

  @@index([sujetoTipo, voluntarioId])
  @@index([sujetoTipo, grupoId])
  @@index([recursoTipo, recursoId])
}

// ── INVENTARIO ─────────────────────────────────────────────────────────────────

model CategoriaInventario {
  id          String           @id @default(cuid())
  nombre      String
  descripcion String?
  activo      Boolean          @default(true)
  items       ItemInventario[]
}

model Ubicacion {
  id          String           @id @default(cuid())
  nombre      String
  descripcion String?
  carroId     String?
  carro       Carro?           @relation(fields: [carroId], references: [id], onDelete: SetNull)
  activo      Boolean          @default(true)
  items       ItemInventario[]
}

enum EstadoItemInventario {
  OPERATIVO
  EN_MANTENCION
  FUERA_DE_SERVICIO
  PERDIDO
}

model ItemInventario {
  id          String               @id @default(cuid())
  nombre      String
  descripcion String?
  categoriaId String
  categoria   CategoriaInventario  @relation(fields: [categoriaId], references: [id])
  ubicacionId String
  ubicacion   Ubicacion            @relation(fields: [ubicacionId], references: [id])
  codigo      String?
  estado      EstadoItemInventario @default(OPERATIVO)
  cantidad    Int                  @default(1)
  createdAt   DateTime             @default(now())
}

// ── CHECKLISTS ─────────────────────────────────────────────────────────────────

enum TipoFrecuenciaChecklist {
  ROLLING
  POR_CAMBIO_TURNO
  ANTES_DE_USO
}

enum TipoAlcanceChecklist {
  ITEM_INVENTARIO
  CATEGORIA_INVENTARIO
  UBICACION
}

model ChecklistTemplate {
  id               String                  @id @default(cuid())
  nombre           String
  descripcion      String?
  alcanceTipo      TipoAlcanceChecklist
  alcanceId        String
  tipoFrecuencia   TipoFrecuenciaChecklist
  intervaloMinutos Int?
  activo           Boolean                 @default(true)
  items            ChecklistTemplateItem[]
  ejecuciones      ChecklistEjecucion[]

  @@index([alcanceTipo, alcanceId])
}

enum TipoPreguntaChecklist {
  PASA_FALLA
  NUMERO
  SELECTOR
  MATRIZ
  TEXTO
}

model ChecklistTemplateItem {
  id                  String                @id @default(cuid())
  checklistTemplateId String
  checklistTemplate   ChecklistTemplate     @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)
  orden               Int
  descripcion         String
  tipoPregunta        TipoPreguntaChecklist @default(PASA_FALLA)
  // Forma según tipoPregunta — ver checklists.service.ts validarConfiguracion():
  // PASA_FALLA: null | NUMERO: { min?, max? } | SELECTOR: { opciones: string[], multiple: boolean }
  // MATRIZ: { filas: string[], columnas: string[] } | TEXTO: null
  configuracion       Json?
}

model ChecklistEjecucion {
  id                     String                   @id @default(cuid())
  checklistTemplateId    String
  checklistTemplate      ChecklistTemplate        @relation(fields: [checklistTemplateId], references: [id])
  ejecutadoPorId         String
  ejecutadoPor           Voluntario               @relation(fields: [ejecutadoPorId], references: [id])
  fechaEjecucion         DateTime                 @default(now())
  observacionesGenerales String?
  items                  ChecklistEjecucionItem[]

  @@index([checklistTemplateId, fechaEjecucion])
}

model ChecklistEjecucionItem {
  id                      String                @id @default(cuid())
  checklistEjecucionId    String
  checklistEjecucion      ChecklistEjecucion    @relation(fields: [checklistEjecucionId], references: [id], onDelete: Cascade)
  checklistTemplateItemId String
  descripcion             String
  // Snapshot del tipoPregunta del ChecklistTemplateItem al momento de
  // ejecutar — mismo motivo que descripcion: si el tipo de la pregunta
  // cambia después, el historial debe seguir mostrando lo que realmente
  // se respondió en su momento.
  tipoPregunta            TipoPreguntaChecklist
  // Forma según tipoPregunta (snapshotted arriba):
  // PASA_FALLA: boolean | NUMERO: number | SELECTOR: string | string[]
  // MATRIZ: { fila: string; columna: string }[] (array, no Record — jsonb no
  // garantiza orden de claves) | TEXTO: string
  respuesta               Json
  observacion             String?
}

// ── NOTIFICACIONES ──────────────────────────────────────────────────────────────

enum TipoNotificacion {
  CHECKLIST_VENCIDO
  PERMISO_SOLICITADO
  PERMISO_APROBADO
  PERMISO_RECHAZADO
}

enum PlataformaDispositivo {
  WEB
  ANDROID
  IOS
}

model Notificacion {
  id           String           @id @default(cuid())
  voluntarioId String
  voluntario   Voluntario       @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)
  tipo         TipoNotificacion
  titulo       String
  cuerpo       String
  datos        Json?
  leida        Boolean          @default(false)
  createdAt    DateTime         @default(now())

  @@index([voluntarioId, leida])
  @@index([voluntarioId, createdAt])
}

model DispositivoNotificacion {
  id           String                @id @default(cuid())
  voluntarioId String
  voluntario   Voluntario            @relation(fields: [voluntarioId], references: [id], onDelete: Cascade)
  token        String                @unique
  plataforma   PlataformaDispositivo
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
}
